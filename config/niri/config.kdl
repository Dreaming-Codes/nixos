input {
    keyboard {
        xkb {
            layout "us"
            variant "intl"
        }
    }

    touchpad {
        tap
        natural-scroll
        drag false
        // Clickpad zones: middle third would emit middle-click with button-areas.
        // clickfinger = 1 finger left, 2 right (no middle-by-pressing-center).
        click-method "clickfinger"
    }

    tablet {
        map-to-output "current"
    }

    // Built-in panel digitizer (ELAN). Without this, absolute touch is mapped
    // across the whole layout, so with an external monitor presses on the
    // laptop hit the wrong output.
    touch {
        map-to-output "eDP-1"
    }

    focus-follows-mouse
    warp-mouse-to-focus mode="center-xy"
}

prefer-no-csd

screenshot-path "~/Pictures/Screenshots/Screenshot from %Y-%m-%d %H-%M-%S.png"

window-rule {
    match app-id=r#"^org\.wezfurlong\.wezterm$"#
    default-column-width {}
}

window-rule {
    match app-id=r#"firefox$"# title="^Picture-in-Picture$"
    open-floating true
}

window-rule {
    match app-id=r#"^xwaylandvideobridge$"#
    opacity 0.0
    open-floating true
    default-column-width { fixed 1; }
    default-window-height { fixed 1; }
}

include "dms/colors.kdl"
include "dms/cursor.kdl"
include "dms/layout.kdl"
include "dms/alttab.kdl"
include "dms/outputs.kdl"
include "dms/windowrules.kdl"
include "dms/binds.kdl"
include "dms/host-local.kdl"
