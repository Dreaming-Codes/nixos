{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "allow",
    "external_directory": "allow",
    "bash": {
      "*": "allow",
      "git push *": "ask",
      "git push": "ask",
      "gh pr create *": "ask",
      "gh pr edit *": "ask",
      "gh pr merge *": "ask",
      "gh pr close *": "ask",
      "glab mr create *": "ask",
      "glab mr update *": "ask",
      "glab mr merge *": "ask",
      "glab mr close *": "ask"
    }
  },
  "plugin": [
    "@mohak34/opencode-notifier@latest"
  ],
  "agent": {
    "build": {
      "model": "amazon-bedrock/anthropic.claude-opus-4-8"
    },
    "explore": {
      "model": "amazon-bedrock/anthropic.claude-opus-4-8"
    }
  },
  "lsp": {
    "rust": {
      "command": [
        "rust-analyzer"
      ],
      "initialization": {
        "rust-analyzer": {
          "check": {
            "command": "clippy"
          }
        }
      }
    }
  }
}
